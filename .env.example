DATABASE_URL="mysql://dev:dev@localhost:3307/learning_effect"

# Better Auth — generate a secret with `openssl rand -hex 32`
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Workflow SDK — self-hosted MySQL world (durable storage, queue, streaming).
# The world reuses DATABASE_URL and keeps its tables in a separate `workflow`
# schema. Provision it with `pnpm world:setup` (see docker/mysql-init for grants).
WORKFLOW_TARGET_WORLD=@fantasticfour/world-mysql
# Optional: base URL the queue worker calls to run steps. Defaults to
# http://localhost:3000 (the dev server). Override for non-default ports/hosts.
# WORKFLOW_BASE_URL=http://localhost:3000
